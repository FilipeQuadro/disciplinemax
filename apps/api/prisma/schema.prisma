generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USUÁRIOS E AUTENTICAÇÃO
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  avatarUrl    String?
  plan         Plan     @default(FREE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  books              Book[]
  bibleReadings      BibleReading[]
  pomodoroSessions   PomodoroSession[]
  habits             Habit[]
  goals              Goal[]
  achievements       UserAchievement[]
  userLevel          UserLevel?
  kairosInteractions KairosInteraction[]
  kairosProfile      KairosProfile?

  @@map("users")
}

enum Plan {
  FREE
  PREMIUM
  BUSINESS
}

// ============================================================
// LEITURA DE LIVROS
// ============================================================

model Book {
  id         String     @id @default(cuid())
  userId     String
  title      String
  author     String?
  coverUrl   String?
  totalPages Int
  pagesRead  Int        @default(0)
  status     BookStatus @default(READING)
  startedAt  DateTime   @default(now())
  finishedAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("books")
}

enum BookStatus {
  WANTS_TO_READ
  READING
  FINISHED
  PAUSED
  ABANDONED
}

// ============================================================
// LEITURA BÍBLICA
// ============================================================

model BibleReading {
  id      String   @id @default(cuid())
  userId  String
  book    String
  chapter Int
  readAt  DateTime @default(now())
  planId  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, book, chapter])
  @@map("bible_readings")
}

model BibleReadingPlan {
  id            String  @id @default(cuid())
  name          String
  description   String?
  totalChapters Int
  durationDays  Int
  isDefault     Boolean @default(false)
}

// ============================================================
// POMODORO
// ============================================================

model PomodoroSession {
  id          String      @id @default(cuid())
  userId      String
  durationMin Int
  breakMin    Int
  type        SessionType @default(FOCUS)
  taskId      String?
  startedAt   DateTime    @default(now())
  completedAt DateTime?
  isCompleted Boolean     @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pomodoro_sessions")
}

enum SessionType {
  FOCUS
  SHORT_BREAK
  LONG_BREAK
}

// ============================================================
// HÁBITOS E STREAKS
// ============================================================

model Habit {
  id          String         @id @default(cuid())
  userId      String
  name        String
  description String?
  icon        String?
  color       String?
  frequency   HabitFrequency @default(DAILY)
  targetCount Int            @default(1)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  logs HabitLog[]
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("habits")
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  userId    String
  date      DateTime @db.Date
  count     Int      @default(1)
  note      String?
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@map("habit_logs")
}

enum HabitFrequency {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

model Streak {
  id             String     @id @default(cuid())
  userId         String
  type           StreakType
  currentCount   Int        @default(0)
  bestCount      Int        @default(0)
  lastActiveDate DateTime   @db.Date
  updatedAt      DateTime   @updatedAt

  @@unique([userId, type])
  @@map("streaks")
}

enum StreakType {
  APP_ACCESS
  BOOK_READING
  BIBLE_READING
  POMODORO
  HABIT_COMPLETION
}

// ============================================================
// GAMIFICAÇÃO
// ============================================================

model Achievement {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  description String
  iconUrl     String?
  xpReward    Int             @default(0)
  tier        AchievementTier @default(BRONZE)

  users UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model UserLevel {
  userId    String   @id
  xp        Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AchievementTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

// ============================================================
// METAS
// ============================================================

model Goal {
  id           String    @id @default(cuid())
  userId       String
  title        String
  description  String?
  type         GoalType
  targetValue  Float
  currentValue Float     @default(0)
  deadline     DateTime?
  isCompleted  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum GoalType {
  BOOK_PAGES
  BIBLE_CHAPTERS
  POMODORO_SESSIONS
  HABIT_STREAK
  CUSTOM
}

// ============================================================
// KAIROS (IA)
// ============================================================

model KairosProfile {
  userId      String   @id
  personality String   @default("encorajador")
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KairosInteraction {
  id          String   @id @default(cuid())
  userId      String
  agentType   String
  messageType String
  content     String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("kairos_interactions")
}
