# ===================================================
# DISCIPLINA APP - Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# ===================================================

# SUPABASE (obrigatório) - https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...sua_chave_anon
SUPABASE_SERVICE_ROLE_KEY=eyJ...sua_service_role_key

# VAPID (para push notifications)
# Gerar em: https://vapidkeys.com/ ou com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BK...sua_chave_publica
VAPID_PRIVATE_KEY=sua_chave_privada

# CRON - Segredo para proteger a rota do cron
CRON_SECRET=seu_segredo_aleatorio_aqui

# GEMINI AI (opcional, gratuito) - https://aistudio.google.com
GEMINI_API_KEY=AIzaSy...sua_chave

# CALLMEBOT WhatsApp (opcional, gratuito)
# O usuário configura via interface do app
