{
  "name": "disciplina-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "setup": "npm install && node -e \"require('fs').copyFileSync('.env.local.txt', '.env.local')\" || true",
    "build": "next build",
    "cap:copy": "npx cap copy",
    "cap:add:ios": "npx cap add ios",
    "cap:open:ios": "npx cap open ios",
    "start": "next start",
    "pm2:start": "npx pm2 start ecosystem.config.js --only disciplina-app && npx pm2 save",
    "pm2:stop": "npx pm2 stop disciplina-app || true",
    "pm2:logs": "npx pm2 logs disciplina-app",
    "lint": "next lint"
  },
  "dependencies": {
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/push-notifications": "^8.1.1",
    "@parse/node-apn": "^7.1.0",
    "@supabase/ssr": "^0.4.0",
    "@supabase/supabase-js": "^2.44.2",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.3.0",
    "lucide-react": "^0.400.0",
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.4.1",
    "tailwind-merge": "^2.4.0",
    "web-push": "^3.6.7",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "pm2": "^5.3.0",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.6",
    "typescript": "^5"
  }
}
